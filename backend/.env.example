# Copy to .env and fill in. .env is gitignored.
# Create an API key in the Capital.com web app: Settings > API integrations.
# Use a DEMO account while developing.

CAPITAL_ENV=demo                 # demo | live (the chart data feed)
CAPITAL_API_KEY=your_api_key
CAPITAL_IDENTIFIER=you@email.com # the account login email
CAPITAL_PASSWORD=your_api_key_custom_password

# Live feed: promotes the live host to its own "capital-live" data broker (own
# session/quotes), carrying an in-app paper sim ("capital-live:paper") plus the
# real-money dealing account ("capital-live:live", a Live tab in the dock). Generate
# a LIVE "Read & Trade" API key in the Capital.com web app and set its key + custom
# password below. The login is the same account, so CAPITAL_LIVE_IDENTIFIER is
# optional (falls back to CAPITAL_IDENTIFIER). Registers only when key + password
# are set.
CAPITAL_LIVE_API_KEY=your_live_api_key
CAPITAL_LIVE_PASSWORD=your_live_api_key_custom_password
CAPITAL_LIVE_IDENTIFIER=         # optional; defaults to CAPITAL_IDENTIFIER

# --- IG (labs.ig.com Web API) ---
# Generate keys in the IG web platform: Settings > API keys (one per env). Demo
# and live are SEPARATE hosts/keys/logins. A side registers as broker "ig-demo" /
# "ig-live" only when all three of its vars are set, so you can wire demo alone.
IG_DEMO_API_KEY=your_ig_demo_api_key
IG_DEMO_IDENTIFIER=your_ig_demo_username
IG_DEMO_PASSWORD=your_ig_demo_password
IG_LIVE_API_KEY=your_ig_live_api_key
IG_LIVE_IDENTIFIER=your_ig_live_username
IG_LIVE_PASSWORD=your_ig_live_password
