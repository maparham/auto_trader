# deploy/ec2/compute.env.example
# Copy to /etc/auto-trader/compute.env on the instance and fill in. Never commit
# the filled file. Same variables the Fly host had as secrets (docs/deploy-compute.md).
# IMPORTANT: values must be UNQUOTED and contain only alphanumerics, dashes, and
# underscores. This file is read by BOTH `docker --env-file` (which keeps raw
# values) and bash `source` (which strips quotes and interprets metacharacters);
# a quoted or metacharacter-containing API_TOKEN gives the container and the
# watchdog different tokens and the instance never self-stops.
REQUIRE_API_TOKEN=1
COMPUTE_ONLY=1
API_TOKEN=change-me
# Broker credentials (same names as backend/.env) go here too:
# CAPITAL_API_KEY=...
